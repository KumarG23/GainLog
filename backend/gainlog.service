[Unit]
Description=GainLog FastAPI Backend
After=network.target

[Service]
Type=simple
User=gainlog
Group=gainlog
WorkingDirectory=/opt/gainlog/backend
ExecStart=/opt/gainlog/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
